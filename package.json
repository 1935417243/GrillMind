{
  "name": "grillmind",
  "version": "0.1.2",
  "private": true,
  "description": "智面 · AI 技术面试模拟器",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node --watch src/index.js",
    "dev:frontend": "cd frontend && npx vite",
    "build": "cd frontend && npx vite build --outDir ../backend/public",
    "start": "cd backend && node src/index.js",
    "db:init": "cd backend && node src/db/init.js",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && electron-builder --win"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.grillmind.app",
    "productName": "GrillMind",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "!backend/node_modules",
      "!backend/data/**",
      "!backend/uploads/**",
      "!frontend/**",
      "!node_modules/**"
    ],
    "extraResources": [],
    "afterPack": "./electron/afterPack.js",
    "asar": false,
    "mac": {
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "智面需要使用麦克风进行语音面试"
      },
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "GrillMind",
      "uninstallDisplayName": "GrillMind"
    }
  }
}
